# ============================================
# 环境变量配置模板
# 复制此文件为 .env.personal 并填入你的实际配置
# 注意：.env.personal 不应该提交到版本控制
# ============================================

# ========== Conda 配置 ==========
# Conda 安装路径（根据你的实际安装位置修改）
# 示例: /home/username/miniconda3, /opt/miniconda3, ~/anaconda3
export CONDA_ROOT=/path/to/your/miniconda3

# 要激活的 Conda 环境名称
export CONDA_ENV=your_env_name

# ========== 数据路径 ==========
# 数据集根目录（绝对路径）
export DATA_DIR=/path/to/your/data

# HuggingFace 缓存目录
export HF_HOME=/path/to/your/hf_cache

# ========== API Keys ==========
# Weights & Biases API Key（从 https://wandb.ai/authorize 获取）
export WANDB_API_KEY=your_wandb_api_key_here

# WandB 团队/用户名
export WANDB_ENTITY=your_wandb_username

# WandB 项目名称
export WANDB_PROJECT=your_project_name

# Working Directory
export PYTHONPATH=$PWD